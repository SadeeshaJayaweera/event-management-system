# Backend Services Environment Configuration Example
# Copy this to .env and update with your values

# Eureka Server
EUREKA_SERVER_PORT=8761
EUREKA_SERVER_URL=http://localhost:8761/eureka/

# API Gateway
API_GATEWAY_PORT=8080

# Auth Service
AUTH_SERVICE_PORT=8082
AUTH_DB_URL=jdbc:h2:mem:authdb
AUTH_DB_USERNAME=sa
AUTH_DB_PASSWORD=

# Event Service
EVENT_SERVICE_PORT=8083
EVENT_DB_URL=jdbc:h2:mem:eventdb
EVENT_DB_USERNAME=sa
EVENT_DB_PASSWORD=

# Attendee Service
ATTENDEE_SERVICE_PORT=8084
ATTENDEE_DB_URL=jdbc:h2:mem:attendeedb
ATTENDEE_DB_USERNAME=sa
ATTENDEE_DB_PASSWORD=

# Ticket Service
TICKET_SERVICE_PORT=8085
TICKET_DB_URL=jdbc:h2:mem:ticketdb
TICKET_DB_USERNAME=sa
TICKET_DB_PASSWORD=

# Notification Service
NOTIFICATION_SERVICE_PORT=8086
NOTIFICATION_DB_URL=jdbc:h2:mem:notificationdb
NOTIFICATION_DB_USERNAME=sa
NOTIFICATION_DB_PASSWORD=

# Analytics Service
ANALYTICS_SERVICE_PORT=8087
ANALYTICS_DB_URL=jdbc:h2:mem:analyticsdb
ANALYTICS_DB_USERNAME=sa
ANALYTICS_DB_PASSWORD=

# Admin Service
ADMIN_SERVICE_PORT=8088
ADMIN_DB_URL=jdbc:h2:mem:admindb
ADMIN_DB_USERNAME=sa
ADMIN_DB_PASSWORD=

# Common Configuration
SPRING_PROFILES_ACTIVE=local
LOGGING_LEVEL=INFO

