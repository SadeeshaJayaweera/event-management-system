// src/app/api/auth/[...nextauth]/route.ts
import NextAuth, { NextAuthOptions } from 'next-auth';
import GoogleProvider from 'next-auth/providers/google';
import CredentialsProvider from 'next-auth/providers/credentials';

const authOptions: NextAuthOptions = {
  providers: [
    // Google OAuth Provider
    GoogleProvider({
      clientId: process.env.GOOGLE_CLIENT_ID || '',
      clientSecret: process.env.GOOGLE_CLIENT_SECRET || '',
    }),
    
    // Keep existing email/password login
    CredentialsProvider({
      name: 'Credentials',
      credentials: {
        email: { label: 'Email', type: 'email' },
        password: { label: 'Password', type: 'password' },
      },
      async authorize(credentials) {
        if (!credentials?.email || !credentials?.password) {
          return null;
        }

        try {
          // Your existing login logic
          const response = await fetch(`${process.env.NEXT_PUBLIC_API_URL}/api/auth/login`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              email: credentials.email,
              password: credentials.password,
            }),
          });

          if (!response.ok) {
            return null;
          }

          const data = await response.json();
          return {
            id: data.user.id,
            email: data.user.email,
            name: `${data.user.firstName} ${data.user.lastName}`,
            accessToken: data.token,
          };
        } catch (error) {
          console.error('Auth error:', error);
          return null;
        }
      },
    }),
  ],

  callbacks: {
    async signIn({ user, account, profile }) {
      // Handle Google OAuth sign-in
      if (account?.provider === 'google') {
        try {
          // Check if user exists in your backend
          const checkResponse = await fetch(
            `${process.env.NEXT_PUBLIC_API_URL}/api/auth/check-email?email=${user.email}`
          );

          if (checkResponse.ok) {
            // User exists, log them in
            const loginResponse = await fetch(
              `${process.env.NEXT_PUBLIC_API_URL}/api/auth/social-login`,
              {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  email: user.email,
                  provider: 'google',
                  providerId: account.providerAccountId,
                }),
              }
            );

            if (loginResponse.ok) {
              const data = await loginResponse.json();
              user.accessToken = data.token;
              return true;
            }
          } else {
            // User doesn't exist, create new account
            const names = user.name?.split(' ') || ['', ''];
            const registerResponse = await fetch(
              `${process.env.NEXT_PUBLIC_API_URL}/api/auth/register`,
              {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  firstName: names[0] || 'User',
                  lastName: names.slice(1).join(' ') || '',
                  email: user.email,
                  password: Math.random().toString(36).substring(7), // Random password
                  phone: '',
                  role: 'USER',
                  provider: 'google',
                  providerId: account.providerAccountId,
                }),
              }
            );

            if (registerResponse.ok) {
              const data = await registerResponse.json();
              user.accessToken = data.token;
              return true;
            }
          }
        } catch (error) {
          console.error('Google sign-in error:', error);
          return false;
        }
      }

      return true;
    },

    async jwt({ token, user, account }) {
      // Add access token to JWT
      if (user) {
        token.accessToken = user.accessToken;
        token.id = user.id;
      }
      return token;
    },

    async session({ session, token }) {
      // Add user info to session
      if (token) {
        session.user.id = token.id as string;
        session.accessToken = token.accessToken as string;
      }
      return session;
    },
  },

  pages: {
    signIn: '/auth/login',
    signOut: '/auth/login',
    error: '/auth/login',
  },

  session: {
    strategy: 'jwt',
  },

  secret: process.env.NEXTAUTH_SECRET,
};

const handler = NextAuth(authOptions);

export { handler as GET, handler as POST };
